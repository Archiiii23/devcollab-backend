## Required
# MongoDB Atlas connection string (Atlas → Connect → Drivers)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/devcollab?retryWrites=true&w=majority

## CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:8080,https://your-frontend.vercel.app

## Optional — public URLs (used by OAuth callbacks)
APP_BASE_URL=https://your-backend.vercel.app
FRONTEND_BASE_URL=https://your-frontend.vercel.app

## Optional — pin the session cookie to a parent domain
SESSION_COOKIE_DOMAIN=

## AI (optional — falls back to deterministic mock)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

## Integrations (all optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
