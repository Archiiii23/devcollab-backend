{
  "name": "devcollab-server",
  "version": "1.0.0",
  "private": true,
  "description": "DevCollab MERN backend (Express + MongoDB on Vercel Functions)",
  "main": "api/index.ts",
  "scripts": {
    "dev": "tsx watch src/local-dev.ts",
    "typecheck": "tsc --noEmit",
    "build": "echo 'No build step needed — @vercel/node compiles TS on demand'",
    "seed": "tsx src/seed-cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.10.1",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@vercel/node": "^3.2.29",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
